# Put Bazel’s workspace symlinks in dist/ output folder
build --symlink_prefix=../dist/bazel-

# Basic Bazel configuration
build --cxxopt=-std=c++20
build --macos_minimum_os=10.15

# Test configuration
test --test_output=all
test --test_summary=detailed

# clang-tidy
build:clang-tidy --aspects @bazel_clang_tidy//clang_tidy:clang_tidy.bzl%clang_tidy_aspect
build:clang-tidy --output_groups=report
build:clang-tidy --@bazel_clang_tidy//:clang_tidy_config=//:clang_tidy_config
build:clang-tidy --@bazel_clang_tidy//:clang_tidy_executable=//:homebrew_clang_tidy

# Fix libstdc++ compatibility issues in CI
build:linux --linkopt=-static-libgcc
build:linux --linkopt=-static-libstdc++
test:linux --linkopt=-static-libgcc
test:linux --linkopt=-static-libstdc++
